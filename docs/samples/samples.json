{
    "package": "maestro",
    "version": "0.1",
    "samples": [
                {
            "name": "hello-world",
            "path": "no-k8s/docker",
            "artifacts": [
                {
                    "file": "target.yaml",
                    "type": "target",
                    "name": "sample-local-target"
                },
                {
                    "file": "solution.yaml",
                    "type": "solution",
                    "name": "sample-prometheus-server" 
                }, 
                {
                    "file": "solution-version.yaml",
                    "type": "solutionversion",
                    "name": "sample-prometheus-server-v-v1" 
                }, 
                {
                    "file": "instance.yaml",
                    "type": "instance",
                    "name": "sample-prometheus-instance"                             
                }
            ],            
            "description": "Deploy a Prometheus server on Docker",
            "description-long": "This sample registers your current machine as a <C>Target</C>, defines a <C>SolutionVersion</C> with a Prometheus component (Docker: prom/Prometheus), and deploys the SolutionVersion to the Target by creating an <C>Instance</C> object. When the Instance is deployed, a <G>sample-k8s-scoe</G> namespace is created, and a LoadBalancer service named <G>sample-prometheus-instance</G> is created.",
            "postActions": 
                [                                   
                    {
                        "command": "echo",
                        "args": [
                           "Navigate to http://localhost:9090/ to access the Promethus portal (it may take a few seconds for the Prometheus server to be ready)"                           
                        ]
                    }                    
                ],
            "requires":["Docker"]
        },
        {
            "name": "hello-k8s",
            "path": "k8s/hello-world",
            "artifacts": [
                {
                    "file": "target.yaml",
                    "type": "target",
                    "name": "sample-k8s-target"
                },
                {
                    "file": "solution.yaml",
                    "type": "solution",
                    "name": "sample-prometheus-server" 
                }, 
                {
                    "file": "solution-version.yaml",
                    "type": "solutionversion",
                    "name": "sample-prometheus-server-v-v1" 
                }, 
                {
                    "file": "instance.yaml",
                    "type": "instance",
                    "name": "sample-prometheus-instance"                             
                }
            ],            
            "description": "Deploy a Prometheus server on a K8s target",
            "description-long": "This sample registers your current K8s cluster as a <C>Target</C>, defines a <C>SolutionVersion</C> with a Prometheus component (Docker: prom/Prometheus), and deploys the SolutionVersion to the Target by creating an <C>Instance</C> object. When the Instance is deployed, a <G>sample-k8s-scoe</G> namespace is created, and a LoadBalancer service named <G>sample-prometheus-instance</G> is created.",
            "postActions": 
                [
                    {
                        "command": "kubectl",
                        "args": [
                           "get",
                           "svc",
                           "sample-prometheus-instance",
                           "-n",
                           "sample-k8s-scope",
                           "-o",
                           "jsonpath='{$.status.loadBalancer.ingress[0].ip}'"
                        ]
                    },                                        
                    {
                        "command": "echo",
                        "args": [
                           "Navigate to http://$(1):9090/ to access the Promethus portal (it may take a few minutes for the LoadBalancer to be provisioned)"                           
                        ]
                    }                    
                ],
            "requires":["k8s"]
        },
        {
            "name": "hello-iot-edge",
            "path": "iot-edge/simulated-temperature-sensor",
            "artifacts": [
                {
                    "file": "target.yaml",
                    "type": "target",
                    "name": "sample-iot-edge-target",
                    "parameters": [
                        {
                            "name": "iot-hub-key",
                            "value": "",
                            "replace": "<IoT Hub Key>"
                        },
                        {
                            "name": "iot-hub-name",
                            "value": "",
                            "replace": "<IoT Hub Name>"
                        },
                        {
                            "name": "iot-hub-key-name",
                            "value": "iothubowner",
                            "replace": "<IoT Hub Key Name>"
                        },
                        {
                            "name": "device-name",
                            "value": "",
                            "replace": "<Device Name>"
                        }
                    ]
                },
                {
                    "file": "solution.yaml",
                    "type": "solution",
                    "name": "sample-simulated-temperature-sensor" 
                }, 
                {
                    "file": "solution-version.yaml",
                    "type": "solutionversion",
                    "name": "sample-simulated-temperature-sensor-v-v1"
                }, 
                {
                    "file": "instance-1.yaml",
                    "type": "instance",
                    "name": "sample-iot-edge-instance-1"
                }, 
                {
                    "file": "instance-2.yaml",
                    "type": "instance",
                    "name": "sample-iot-edge-instance-2"
                }
            ],
            "requires":["Azure IoT Edge"],
            "description": "Deploy IoT Edge simulated sensor module",
            "description-long": "This sample deploys two instances of IoT Edge simulated sensor module to an IoT Edge device. It creats a <C>SolutionVersion</C> with an IoT simulated sensor component (https://hub.docker.com/_/microsoft-azureiotedge-simulated-temperature-sensor), an IoT Edge <C>Target</C>, and two <C>Instance</C>s - <G>sample-iot-edge-instance-1</G> and <G>sample-iot-edge-instance-2</G> on the same IoT Edge device.",
            "postActions": 
            [
                {
                    "command": "echo",
                    "args": [
                       "Navigate to https://portal.azure.com/ to check your IoT Edge device"                           
                    ]
                }                    
            ]
        },
        {
            "name": "stage-on-k8s",
            "path": "k8s/staged",
            "artifacts": [
                {
                    "file": "target.yaml",
                    "type": "target",
                    "name": "sample-staged-k8s"
                },
                {
                    "file": "solution.yaml",
                    "type": "solution",
                    "name": "sample-staged-solutionversion" 
                }, 
                {
                    "file": "solution-version.yaml",
                    "type": "solutionversion",
                    "name": "sample-staged-solutionversion-v-v1"
                }, 
                {
                    "file": "instance.yaml",
                    "type": "instance",
                    "name": "sample-staged-instance"
                }
            ],
            "description": "Stage a dummy component on a K8s target",
            "description-long": "This sample registers your current K8s target as a Symphony <C>Target</C>, defines a dummy <C>SolutionVersion</C> with a single component with a <G>foo=bar</G> property, and stages the SolutionVersion on the Target object by creating an <C>Instance</C> object.",
            "requires":["k8s"],
            "postActions": 
            [
                {
                    "command": "maestro",
                    "args": [
                       "get",
                       "catalogversion",
                       "-n",
                       "sample-staged-instance-sample-staged-k8s-v-v1",
                       "--json-path",
                       "$.metadata.name",
                       "--no-header"
                    ]                    
                },
                {
                    "command": "echo",
                    "args": [
                       "Target artifact is staged at CatalogVersion object$(1)"                           
                    ]
                }                          
            ]
        },
        {
            "name": "simple-campaign",
            "path": "campaigns/hello-world",
            "artifacts": [
                {
                    "file": "campaign.yaml",
                    "type": "campaign",
                    "name": "hello-world"
                },
                {
                    "file": "campaign-version.yaml",
                    "type": "campaignversion",
                    "name": "hello-world-v-version1"
                },
                {
                    "file": "activation.yaml",
                    "type": "activation",
                    "name": "hello-world-activation" 
                }
            ],
            "description": "Run a simple counter workflow",
            "description-long": "This sample activates a simple campaign that outputs a received activation parameter.",
            "requires":[]
        },
          {
            "name": "counter-campaign",
            "path": "campaigns/counter",
            "artifacts": [
                {
                    "file": "campaign.yaml",
                    "type": "campaign",
                    "name": "counter-campaign"
                },
                {
                    "file": "campaign-version.yaml",
                    "type": "campaignversion",
                    "name": "counter-campaign-v-version1"
                },
                {
                    "file": "activation.yaml",
                    "type": "activation",
                    "name": "counter-activation" 
                }
            ],
            "description": "Run a simple counter workflow",
            "description-long": "This sample activates a simple campaign that counts up from an initial value.",
            "requires":[]
        }
    ]
}